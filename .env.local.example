# Plantilla de variables de entorno para EZ Trader
# Copia este archivo como ".env.local" y completa los valores reales.
# El archivo .env.local NO se sube a Git (está en .gitignore).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Datos de mercado (ver docs/fuentes-datos.md) ---
TWELVE_DATA_API_KEY=
FRED_API_KEY=
BANCO_CENTRAL_USER=
BANCO_CENTRAL_PASS=
